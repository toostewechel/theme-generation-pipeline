{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["vite/client", "node"],
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "paths": {
      "@ui": ["./src/ui/index.ts"],
      "@ui/*": ["./src/ui/*"]
    }
  },
  "include": ["src"]
}
